# pyenv
#   For a library or package, you might want to ignore these files since the values are
#   specific to the developer's system of choice.
# .python-version

# pipenv
#   According to pypa/pipenv#1268, user should occupy both Pipfile and Pipfile.lock in a dev environment,
#   where the dependencies are installed and maintained.
# Pipfile
# Pipfile.lock

# poetry
#   Similar to Pipfile, poetry.lock contains specific versions of dependencies
#   which are usually committed to version control.
# poetry.lock

# pdm
#   Similar to Pipfile, pdm.lock contains specific versions of dependencies
#   which are usually committed to version control.
# pdm.lock

